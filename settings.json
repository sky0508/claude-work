{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "mcpServers": {
    "jva-crm": {
      "command": "node",
      "args": ["/Users/sorasasaki/jva-crm/mcp-server/index.js"]
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/sorasasaki/claude-workspace && git status --porcelain 2>/dev/null | grep -qE 'CLAUDE\\.md|MEMORY\\.md|settings\\.json|skills/' && git add -A && git diff --cached --quiet || (git commit -m \"auto: sync config [$(date '+%Y-%m-%d %H:%M')]\" -q && git push origin main -q) || true"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "secretary@cc-secretary": true,
    "company@cc-company": true,
    "superpowers@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "cc-secretary": {
      "source": {
        "source": "github",
        "repo": "Shin-sibainu/cc-secretary"
      }
    },
    "cc-company": {
      "source": {
        "source": "github",
        "repo": "Shin-sibainu/cc-company"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754087472616
  }
}
