# Discord Webhook URL for agent notifications
# Create at: Server Settings > Integrations > Webhooks > New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Per-agent Discord Webhook overrides (optional)
# If set, these take precedence over DISCORD_WEBHOOK_URL for the specific agent
DISCORD_WEBHOOK_OUTREACH=https://discord.com/api/webhooks/YOUR_OUTREACH_WEBHOOK_ID/YOUR_OUTREACH_WEBHOOK_TOKEN

# Google Sheets ID for lead data storage
# From the spreadsheet URL: docs.google.com/spreadsheets/d/{SHEET_ID}/edit
GOOGLE_SHEETS_ID=YOUR_SPREADSHEET_ID
